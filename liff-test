<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>予約</title>
  <script charset="utf-8" src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>
  <style>
    body {
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: #f0f4f8;
      font-family: system-ui, -apple-system, sans-serif;
    }
    .loader {
      text-align: center;
      color: #555;
    }
    .loader p { margin-top: 12px; font-size: 15px; }
    .spinner {
      width: 40px; height: 40px;
      border: 4px solid #ddd;
      border-top-color: #06c755;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
  <div class="loader">
    <div class="spinner"></div>
    <p>予約画面を開いています…</p>
  </div>

  <script>
    // ============================================================
    // ▼▼▼ 設定：あなたの情報をここに入力してください ▼▼▼

    // LINE公式アカウントのID（例: '@123abcde'）
    const OA_LINE_ID = '@558ybtzq';

    // LIFF ID（LINE DevelopersコンソールのLIFF設定画面で確認できます）
    const LIFF_ID = '2009276936-E6Lu6Spd';

    // Google Apps ScriptのデプロイURL
    // （GASをウェブアプリとしてデプロイした際に発行されるURL）
    const GAS_URL = 'https://script.google.com/macros/s/AKfycbxXi9aVYvbN6LA1MBzJz1c_3VIAo-Rp3wCkGQjiip_J4ArhJzzepjiNNuaaoIxh6t5U/exec';

    // ▲▲▲ 設定ここまで ▲▲▲
    // ============================================================

    // スプレッドシートからテキストを取得してトーク画面へ遷移する
    async function init() {
      let text;

      try {
        // GAS APIからスプレッドシートのテキストを取得
        const res = await fetch(GAS_URL);
        const data = await res.json();
        text = data.text;
      } catch (err) {
        // 取得に失敗した場合のフォールバックテキスト
        console.error('スプレッドシートの取得に失敗しました:', err);

      }

      // LIFFを初期化してからoaMessageへリダイレクト
      try {
        await liff.init({ liffId: LIFF_ID });
        const encodedId   = encodeURIComponent(OA_LINE_ID);
        const encodedText = encodeURIComponent(text);
        const url = `https://line.me/R/oaMessage/${encodedId}/?${encodedText}`;
        liff.openWindow({ url: url, external: false });
      } catch (err) {
        // LIFF初期化に失敗した場合はwindow.location.hrefで直接遷移
        console.error('LIFF init error:', err);
        const encodedId   = encodeURIComponent(OA_LINE_ID);
        const encodedText = encodeURIComponent(text);
        window.location.href = `https://line.me/R/oaMessage/${encodedId}/?${encodedText}`;
      }
    }

    init();
  </script>
</body>
</html>
